# Database Configuration
# Options: mysql, sqlite
DB_DRIVER=sqlite

# MySQL Settings (used when DB_DRIVER=mysql)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=w2t39uh6cc89r6b9_auditr
DB_USER=w2t39uh6cc89r6b9_root
DB_PASS=your_mysql_password_here

# SQLite Settings (used when DB_DRIVER=sqlite)
# For local file: /path/to/database.sqlite
# For Turso: use turso CLI to sync to a local file, then point DB_SQLITE_PATH to it
DB_SQLITE_PATH=database.sqlite

# Application Settings
BASE_URL=http://localhost/sales/
APP_NAME="East African Spirit Sales"
APP_ENV=local

# Turso Database (optional - for reference if using Turso HTTP API)
# TURSO_DATABASE_URL=libsql://your-db.turso.io
# TURSO_AUTH_TOKEN=your-turso-auth-token
